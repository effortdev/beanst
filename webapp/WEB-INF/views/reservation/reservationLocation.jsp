<%@ page language="java" contentType="text/html; charset=UTF-8"
	pageEncoding="UTF-8"%>

<body>

	<!-- =========================================================
     전체 페이지 래퍼
     호텔 사이트 느낌을 위해 아이보리 배경을 사용
========================================================= -->
	<div class="wrap">

		<!-- =========================================================
	     상단 타이틀 영역
	========================================================= -->
		<div class="textBox">

			<div class="top_title fade-up">

				<!-- 영어 타이틀 -->
				<h2 class="en">Location</h2>

				<!-- 설명 문구 -->
				<p class="text">당신의 하루가 머무는 가장 빛나는 공간, Vinst Hotel에 초대합니다.</p>

			</div>

		</div>


		<!-- =========================================================
	     지도 + 오시는길 전체 영역
	========================================================= -->
		<section class="Locationposition">


			<!-- =====================================================
		     왼쪽 영역 (지도 + 주소)
		===================================================== -->
			<div class="LocationAll">
				<div class="LocationLeft">


					<!-- ===============================
			     지도 영역
			=============================== -->
					<div class="LocationMap">

						<img
							src="${pageContext.request.contextPath}/assets/images/reservation/hotel-Local.png"
							alt="hotel_Location" class="mapImg">

						<!-- 지도 위 버튼 (지도 보기 / 구글맵 등 연결 가능) -->
						<div class="overlay">
							<a href="#" class="viewBtn en">VIEW MAP</a>
						</div>

					</div>


					<!-- ===============================
			     주소 영역
			     호텔 사이트 스타일로 제작
			=============================== -->
					<div class="Locationadress">

						<!-- ADDRESS 타이틀 -->
						<h5>ADDRESS</h5>

						<!-- 실제 주소 -->
						<p>경기도 안양시 만안구 안양로314번길 10</p>
						<p>광창빌딩 3층</p>

						<br>

						<!-- 지하철 안내 -->
						<p>지하철 1호선 안양역 → 지하상가 13번 출구</p>

					</div>

				</div>



				<!-- =====================================================
		     오른쪽 영역 (오시는 길 설명)
		===================================================== -->
				<div class="LocationExtra">


					<!-- 오시는길 메인 타이틀 -->
					<div class="localhotel">
						<h4>오시는 길</h4>
					</div>



					<!-- ===============================
			     도보 이용
			=============================== -->
					<h4>도보 이용</h4>

					<p>안양역 1번 출구로 나오신 후</p>
					<p>→ 안양역 로터리 방향 직진</p>
					<p>→ 안양일번가 거리 지나 약 5분 도보 이동</p>
					<p>→ 안양로314번길 방면으로 우회전</p>
					<p>→ 광창빌딩 3층 도착 (총 소요시간 약 7~10분)</p>


					<br> <br>


					<!-- ===============================
			     버스 이용
			=============================== -->
					<h4>버스 이용</h4>

					<p>안양역 앞 버스정류장에서</p>
					<p>→ 3번, 5-2번, 11-3번 버스 탑승</p>
					<p>→ 안양초등학교 또는 만안구청 정류장 하차</p>
					<p>(1정거장, 약 3~5분 소요)</p>
					<p>→ 안양로314번길 방향 도보 3분 이동</p>
					<p>→ 광창빌딩 3층 도착</p>


				</div>
			</div>

		</section>

	</div>


	<!-- JS -->
	<script src="${pageContext.request.contextPath}/assets/js/main.js"></script>

</body>